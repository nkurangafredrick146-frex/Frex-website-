 # Example environment variables for FREX Website

# Core API base URL (parent brand)
NEXT_PUBLIC_API_URL=https://api.frex1.com

# Contact form submission endpoint
CONTACT_FORM_ENDPOINT=https://api.frex1.com/contact

# Feature flags (global)
NEXT_PUBLIC_FEATURE_FLAG=true

# Analytics (optional)
NEXT_PUBLIC_ANALYTICS_ID=UA-XXXXXXXXX-X

# Department-specific (Frex Tech only)
NEXT_PUBLIC_FREXTECH_FEATURE_FLAG=false
